{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "coingeckoanalytical/contracts/bundle_run_event.schema.json",
  "title": "DatabricksBundleRunEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_name",
    "status"
  ],
  "properties": {
    "job_name": { "type": "string" },
    "run_id": { "type": ["string", "null"] },
    "status": {
      "type": "string",
      "enum": ["SUCCESS", "FAILED", "CANCELLED", "RUNNING", "QUEUED", "PENDING"]
    },
    "result_state": { "type": ["string", "null"] },
    "update_time": { "type": ["string", "null"] },
    "duration_ms": { "type": ["integer", "null"], "minimum": 0 }
  }
}
