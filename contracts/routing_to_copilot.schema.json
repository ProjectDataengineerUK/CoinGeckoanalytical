{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "coingeckoanalytical/contracts/routing_to_copilot.schema.json",
  "title": "RoutingToCopilotRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "tenant_id",
    "conversation_id",
    "message_text",
    "retrieval_scope",
    "policy_context",
    "locale"
  ],
  "properties": {
    "request_id": { "type": "string" },
    "tenant_id": { "type": "string" },
    "user_id": { "type": ["string", "null"] },
    "conversation_id": { "type": "string" },
    "message_text": { "type": "string", "minLength": 1 },
    "conversation_summary": { "type": ["string", "null"] },
    "retrieval_scope": { "type": "string" },
    "selected_assets": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "time_range": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" }
      }
    },
    "policy_context": {
      "type": "object",
      "additionalProperties": true
    },
    "locale": { "type": "string" }
  }
}
