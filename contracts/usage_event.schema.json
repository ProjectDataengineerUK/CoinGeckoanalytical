{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "coingeckoanalytical/contracts/usage_event.schema.json",
  "title": "UsageTelemetryEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_time",
    "request_id",
    "tenant_id",
    "route_selected",
    "model_or_engine",
    "latency_ms",
    "response_status"
  ],
  "properties": {
    "event_time": { "type": "string" },
    "request_id": { "type": "string" },
    "tenant_id": { "type": "string" },
    "user_id": { "type": ["string", "null"] },
    "route_selected": {
      "type": "string",
      "enum": ["genie", "copilot", "dashboard_api", "internal_app"]
    },
    "model_or_engine": { "type": "string" },
    "prompt_tokens": { "type": ["integer", "null"], "minimum": 0 },
    "completion_tokens": { "type": ["integer", "null"], "minimum": 0 },
    "total_tokens": { "type": ["integer", "null"], "minimum": 0 },
    "latency_ms": { "type": "integer", "minimum": 0 },
    "cost_estimate": { "type": ["number", "null"], "minimum": 0 },
    "freshness_watermark": { "type": ["string", "null"] },
    "response_status": {
      "type": "string",
      "enum": ["success", "partial", "refused", "error"]
    }
  }
}
